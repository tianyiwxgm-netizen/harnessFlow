# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Runtime state (task boards / verifier reports / events / retros / archive are per-run artifacts)
task-boards/*.json
task-boards/cross-project/*.json
task-boards/legacy/*.json
task-boards.bak-*/
verifier_reports/*.json
supervisor-events/*.jsonl
routing-events/*.jsonl
skills-invoked/*.jsonl
sessions/*.json
retros/*.md
retros/*.notes.json
failure-archive.jsonl
audit-reports/*.json
archive/supervisor_wake/state/*.json

# Keep .gitkeep if we ever add one
!**/.gitkeep

# UI runtime artifacts
ui/.ui.pid
ui/ui.log

# Test E2E artifacts (regenerated on every run; keep .gitkeep)
tests/e2e/artifacts/*.png
tests/e2e/artifacts/*.webm
tests/e2e/artifacts/*.zip

# Git worktrees (superpowers)
.worktrees/

# Claude Code local settings (personal, not for repo)
.claude/settings.local.json

# Venv + coverage + egg-info
.venv/
.coverage
*.egg-info/
